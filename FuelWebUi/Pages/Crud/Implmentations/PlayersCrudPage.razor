@page "/crud/players"
@inherits TemplateCrudPage<PlayerListDto, PlayerFormModel, Player>

<EntityPage TDto="PlayerListDto" TFormModel="PlayerFormModel"
    PageTitle="Players"
    EntityName="Player"
    SuccessMessage="@_successMessage"
    ErrorMessage="@_errorMessage"
    Items="@_items"
    IsLoading="@_isLoading"
    CurrentPage="@_currentPage"
    PageSize="@_pageSize"
    TotalCount="@(_totalCount ?? 0)"
    TotalPages="@_totalPages"
    ShowForm="@_showForm"
    FormModel="@_formModel"
    IsEditMode="@_isEditMode"
    IsSaving="@_isSaving"
    OnAddClicked="ShowAddForm"
    OnRowClick="ShowEditForm"
    OnValidSubmit="OnValidSubmitAsync"
    OnCancel="HideForm"
    OnDelete="DeleteItemAsync"
    NextPage="NextPageAsync"
    PreviousPage="PreviousPageAsync">
    <PlayerForm FormModel="@_formModel" />
</EntityPage>
