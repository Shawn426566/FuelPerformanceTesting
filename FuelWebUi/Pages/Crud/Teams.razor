@page "/crud/teams"
@inject FuelApiClient ApiClient
@inject NavigationManager NavigationManager

@using System.ComponentModel.DataAnnotations
@using FuelWebUi.ApiClient.Models

<h1>Teams</h1>

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <div class="alert alert-success">@SuccessMessage</div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div></div>
            <button class="btn btn-primary" @onclick="ShowAddForm">
                <span class="bi bi-plus-circle me-1"></span> Add Team
            </button>
        </div>

        @if (IsLoading)
        {
            <p>Loading...</p>
        }
        else if (TeamItems.Count == 0)
        {
            <p>No teams found.</p>
        }
        else
        {
            <div class="mb-3 d-flex justify-content-between align-items-center">
                <div>
                    Showing @((CurrentPage - 1) * PageSize + 1) - @Math.Min(CurrentPage * PageSize, TotalCount) of @TotalCount teams
                </div>
                <div class="btn-group">
                    <button class="btn btn-sm btn-outline-primary" @onclick="PreviousPage" disabled="@(CurrentPage == 1)">
                        <span class="bi bi-chevron-left"></span> Previous
                    </button>
                    <button class="btn btn-sm btn-outline-primary" disabled>
                        Page @CurrentPage of @TotalPages
                    </button>
                    <button class="btn btn-sm btn-outline-primary" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">
                        Next <span class="bi bi-chevron-right"></span>
                    </button>
                </div>
            </div>

            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Association</th>
                        <th>Players</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var team in TeamItems)
                    {
                        <tr style="cursor: pointer;" @onclick="() => ShowEditForm(team)">
                            <td>@team.Name</td>
                            <td>@team.AssociationName</td>
                            <td>@team.PlayerCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (ShowForm)
    {
        <div class="col-lg-4" id="edit-form" style="position:sticky;top:20px;height:fit-content;">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">@(IsEditMode ? "Edit Team" : "Add Team")</h5>
                        <button type="button" class="btn-close" @onclick="HideForm"></button>
                    </div>

                    <EditForm Model="NewTeam" OnValidSubmit="SaveTeamAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="NewTeam.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Association</label>
                            <InputSelect class="form-select" @bind-Value="NewTeam.AssociationID">
                                <option value="">Select association</option>
                                @foreach (var assoc in Associations)
                                {
                                    <option value="@assoc.AssociationId">@assoc.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" type="submit" disabled="@IsSaving">
                                @(IsSaving ? "Saving..." : IsEditMode ? "Update Team" : "Add Team")
                            </button>
                            <button class="btn btn-secondary" type="button" @onclick="HideForm">
                                Cancel
                            </button>
                            @if (IsEditMode)
                            {
                                <button class="btn btn-danger ms-auto" type="button" @onclick="DeleteCurrentTeamAsync">
                                    Delete
                                </button>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</div>

<ConfirmDialog @ref="confirmDialog" Title="Delete Team" ConfirmText="Delete" />

@code {
    private ConfirmDialog confirmDialog = default!;
    private List<TeamListDto> TeamItems { get; set; } = new();
    private List<AssociationListDto> Associations { get; set; } = new();
    private TeamFormModel NewTeam { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private bool ShowForm { get; set; }
    private bool IsEditMode { get; set; }
    private int? EditingTeamId { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }

    // Pagination properties
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 30;
    private int TotalCount { get; set; }
    private int TotalPages => TotalCount > 0 ? (int)Math.Ceiling(TotalCount / (double)PageSize) : 1;

    private bool IsPageLoading { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            ErrorMessage = null;
            var teamsTask = ApiClient.Api.Teams.GetAsync(config =>
            {
                config.QueryParameters.SortBy = "name";
                config.QueryParameters.SortDir = "asc";
                config.QueryParameters.Page = CurrentPage;
                config.QueryParameters.PageSize = PageSize;
            });
            var associationsTask = ApiClient.Api.Association.GetAsync(config =>
            {
                config.QueryParameters.Page = 1;
                config.QueryParameters.PageSize = 1000;
            });

            await Task.WhenAll(teamsTask, associationsTask);

            var teamsResult = await teamsTask;
            var associationsResult = await associationsTask;
            TeamItems = teamsResult?.Items ?? new List<TeamListDto>();
            TotalCount = teamsResult?.TotalCount ?? 0;
            Associations = associationsResult?.Items ?? new List<AssociationListDto>();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadTeamsAsync()
    {
        try
        {
            ErrorMessage = null;
            var response = await ApiClient.Api.Teams.GetAsync(config =>
            {
                config.QueryParameters.SortBy = "name";
                config.QueryParameters.SortDir = "asc";
                config.QueryParameters.Page = CurrentPage;
                config.QueryParameters.PageSize = PageSize;
            });
            TeamItems = response?.Items ?? new List<TeamListDto>();
            TotalCount = response?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load teams: {ex.Message}";
        }
    }

    private async Task NextPage()
    {
        if (CurrentPage < TotalPages && !IsPageLoading)
        {
            IsPageLoading = true;
            CurrentPage++;
            await LoadTeamsAsync();
            IsPageLoading = false;
        }
    }

    private async Task PreviousPage()
    {
        if (CurrentPage > 1 && !IsPageLoading)
        {
            IsPageLoading = true;
            CurrentPage--;
            await LoadTeamsAsync();
            IsPageLoading = false;
        }
    }

    private string GetAssociationName(int? associationId) =>
        Associations.FirstOrDefault(a => a.AssociationId == associationId)?.Name ?? "—";

    private void ShowAddForm()
    {
        IsEditMode = false;
        EditingTeamId = null;
        NewTeam = new TeamFormModel();
        ShowForm = true;
        ErrorMessage = null;
        SuccessMessage = null;
    }

    private void ShowEditForm(TeamListDto team)
    {
        IsEditMode = true;
        EditingTeamId = team.TeamId;
        NewTeam = new TeamFormModel
        {
            Name = team.Name ?? string.Empty,
            AssociationID = team.AssociationId
        };
        ShowForm = true;
        ErrorMessage = null;
        SuccessMessage = null;
    }

    private void HideForm()
    {
        ShowForm = false;
        IsEditMode = false;
        EditingTeamId = null;
        NewTeam = new TeamFormModel();
    }

    private async Task SaveTeamAsync()
    {
        if (IsEditMode)
        {
            await UpdateTeamAsync();
        }
        else
        {
            await AddTeamAsync();
        }
    }

    private async Task AddTeamAsync()
    {
        IsSaving = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var request = new Team
            {
                Name = NewTeam.Name?.Trim(),
                AssociationID = NewTeam.AssociationID
            };

            await ApiClient.Api.Teams.PostAsync(request);
            SuccessMessage = "Team added successfully.";
            HideForm();
            await LoadTeamsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to add team: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task UpdateTeamAsync()
    {
        if (!EditingTeamId.HasValue)
        {
            ErrorMessage = "Cannot update team without a valid ID.";
            return;
        }

        IsSaving = true;
        ErrorMessage = null;
        SuccessMessage = null;

        try
        {
            var request = new Team
            {
                TeamID = EditingTeamId.Value,
                Name = NewTeam.Name?.Trim(),
                AssociationID = NewTeam.AssociationID
            };

            await ApiClient.Api.Teams[EditingTeamId.Value].PutAsync(request);
            SuccessMessage = "Team updated successfully.";
            HideForm();
            await LoadTeamsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to update team: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task DeleteCurrentTeamAsync()
    {
        if (!EditingTeamId.HasValue)
        {
            ErrorMessage = "Cannot delete team without a valid ID.";
            return;
        }

        var team = TeamItems.FirstOrDefault(t => t.TeamId == EditingTeamId.Value);
        if (team == null)
        {
            ErrorMessage = "Team not found.";
            return;
        }

        var confirmed = await confirmDialog.ShowAsync($"Delete {team.Name}?\nThis action cannot be undone.");

        if (!confirmed)
        {
            return;
        }

        try
        {
            await ApiClient.Api.Teams[EditingTeamId.Value].DeleteAsync();
            await LoadTeamsAsync();
            SuccessMessage = "Team deleted successfully.";
            HideForm();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to delete team: {ex.Message}";
        }
    }

    private sealed class TeamFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        [Required]
        public int? AssociationID { get; set; }
    }
}
